<layout id="MainLayout">
    <drawable id="CalendarBackground" />

    <label
        id="TitleLabel"
        x="center"
        y="6"
        font="Graphics.FONT_SMALL"
        justification="Graphics.TEXT_JUSTIFY_CENTER"
        color="Graphics.COLOR_WHITE"
    >
        G365 Calendar
    </label>

    <label
        id="NoEventsLabel"
        x="center"
        y="center"
        font="Graphics.FONT_MEDIUM"
        justification="Graphics.TEXT_JUSTIFY_CENTER | Graphics.TEXT_JUSTIFY_VCENTER"
        color="Graphics.COLOR_WHITE"
        visible="false"
    />

    <label
        id="SyncStatusLabel"
        x="center"
        y="bottom"
        font="Graphics.FONT_XTINY"
        justification="Graphics.TEXT_JUSTIFY_CENTER"
        color="Graphics.COLOR_GREEN"
        visible="false"
    />

    <drawable id="Row0Decor" class="EventRowDecorationDrawable" />
    <label id="Row0Title" font="Graphics.FONT_TINY" color="Graphics.COLOR_WHITE" visible="false" />
    <label id="Row0Time" font="Graphics.FONT_XTINY" color="Graphics.COLOR_LT_GRAY" visible="false" />
    <label id="Row0Location" font="Graphics.FONT_XTINY" color="Graphics.COLOR_DK_GRAY" visible="false" />

